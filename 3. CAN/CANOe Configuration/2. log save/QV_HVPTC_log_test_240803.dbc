BA_ "Description" SG_ 3221225472 L_3HKBD_SwOpt1 "Bit0 (CoolSeat):0 - Non CoolSeat/1 ? CoolSeat
 Bit1:(HeatSeat):0 - Non HeatSeat/1 ? HeatSeat
 Bit2:(Seat):0 - 5 Seat/1 - 7 Seat
 Bit3~4:(Type):0 - None/1 - ATC/2 - MTC 
 Bit5:RESERVED   
 Bit6:RESERVED   
 Bit7:RESERVED";
